# ── Base de datos PostgreSQL ──
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password123
POSTGRES_DB=crm_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── JWT ──
